# =========================================================
# 书城管理系统 环境变量配置示例
# ---------------------------------------------------------
# 使用说明：
#   1. 复制本文件为 .env： cp .env.example .env
#   2. 按需修改下列变量的值
#   3. .env 文件已被 .gitignore 忽略，不会被提交到仓库
#   4. 若不创建 .env，应用将使用 application.properties 中的默认值
#      （默认值仅适合本地开发，生产环境务必修改！）
# =========================================================

# 服务端口
SERVER_PORT=8080

# MySQL 数据库配置
DB_URL=jdbc:mysql://localhost:3306/bookshop?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root

# JWT 配置
# 生产环境务必替换为足够长（≥ 32 字节）且随机的字符串
JWT_SECRET=BookshopSystem2025SecretKeyForJwtTokenGenerationMustBeLongEnough
# Token 有效期（毫秒），默认 24 小时
JWT_EXPIRATION=86400000

# 图书封面上传路径
UPLOAD_PATH=src/main/resources/static/uploads/
